# Day 19 lab — env template. Copy to .env and fill in.
# Both paths default to the lite stack; uncomment the docker block to switch.

# ───────────────────────────────────────────────────────────
# Lite path (default) — no services, all in-process
# ───────────────────────────────────────────────────────────
QDRANT_MODE=memory                  # memory | server
EMBEDDING_BACKEND=fastembed         # fastembed | bge-m3 | openai
FEAST_ONLINE_STORE=sqlite           # sqlite | redis
FEAST_OFFLINE_STORE=file            # file | postgres
POSTGRES_HOST_PORT=15432            # host port for docker Postgres when 5432 is occupied

# ───────────────────────────────────────────────────────────
# Docker path — uncomment when you ran setup-docker.sh
# ───────────────────────────────────────────────────────────
# QDRANT_MODE=server
# QDRANT_URL=http://localhost:6333
# FEAST_ONLINE_STORE=redis
# REDIS_URL=redis://localhost:6379/0
# FEAST_OFFLINE_STORE=postgres
# POSTGRES_HOST_PORT=15432
# POSTGRES_URL=postgresql://feast:feast@localhost:15432/feast_offline

# ───────────────────────────────────────────────────────────
# Optional: bonus challenge or §1 swap-in
# ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
